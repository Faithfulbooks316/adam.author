# netlify.toml
# FaithfulBooks Publishing — Adam Joseph Hanrahan Author Site
# Deploy: Connect GitHub repo → Netlify → auto-deploy on push

[build]
  publish = "."          # serves from root (index.html is the entry point)
  command = ""           # static site — no build step needed

# Performance headers
[[headers]]
  for = "/*"
  [headers.values]
    X-Frame-Options = "DENY"
    X-XSS-Protection = "1; mode=block"
    X-Content-Type-Options = "nosniff"
    Referrer-Policy = "strict-origin-when-cross-origin"
    Cache-Control = "public, max-age=0, must-revalidate"

[[headers]]
  for = "/styles.css"
  [headers.values]
    Cache-Control = "public, max-age=31536000, immutable"

[[headers]]
  for = "/app.js"
  [headers.values]
    Cache-Control = "public, max-age=31536000, immutable"

# Redirect bare domain to www (optional — remove if not needed)
# [[redirects]]
#   from = "https://faithfulbooks.com/*"
#   to   = "https://www.faithfulbooks.com/:splat"
#   status = 301

# 404 fallback
[[redirects]]
  from   = "/*"
  to     = "/index.html"
  status = 200
